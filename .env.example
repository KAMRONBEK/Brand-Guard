VITE_APP_DEFAULT_ROUTE = /workbench
VITE_APP_PUBLIC_PATH = /
VITE_APP_API_BASE_URL = /api
# Instagram Comment Reader API (omit in dev to use Vite proxy `/comment-api`)
# VITE_APP_COMMENT_API_BASE_URL = https://comment-api.fapi.uz
# Dev proxy target when using `/comment-api` (default in vite.config.ts)
# VITE_APP_COMMENT_API_PROXY_TARGET = https://comment-api.fapi.uz
VITE_APP_ROUTER_MODE = frontend

# Optional links (omit to hide header / account menu entries)
# VITE_APP_DOCS_URL = https://example.com/docs
# VITE_APP_REPOSITORY_URL = https://github.com/you/brand-guard
# VITE_APP_COMMUNITY_URL = https://discord.gg/your-invite
